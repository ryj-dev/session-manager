{
  "name": "session-manager",
  "version": "0.1.2",
  "description": "Desktop app for managing multiple Claude Code sessions",
  "author": "Ry J",
  "license": "MIT",
  "homepage": "https://github.com/ryj-dev/session-manager#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryj-dev/session-manager.git"
  },
  "bugs": {
    "url": "https://github.com/ryj-dev/session-manager/issues"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "node --test 'src/main/*.test.ts'",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.ryj.session-manager",
    "productName": "Session Manager",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/sqlite-vec/**/*",
      "node_modules/sqlite-vec-darwin-arm64/**/*",
      "node_modules/sqlite-vec-darwin-x64/**/*",
      "node_modules/@huggingface/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "publish": null
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.5.0",
    "d3-force": "^3.0.0",
    "framer-motion": "^11.0.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.2",
    "sqlite-vec": "^0.1.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3-force": "^3.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
